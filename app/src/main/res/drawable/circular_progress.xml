<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:innerRadiusRatio="3.0" android:thicknessRatio="15.0" android:useLevel="false">
            <solid android:color="#ffe0e0e0" />
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270.0" android:toDegrees="270.0">
            <shape android:shape="ring" android:innerRadiusRatio="3.0" android:thicknessRatio="15.0" android:useLevel="true">
                <solid android:color="#ffe0ad3b" />
            </shape>
        </rotate>
    </item>
</layer-list>
